    {
      "name": "http://localhost:8000/api/v1/ingest",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// API Screener Yahoo Finance untuk mengambil saham teraktif/terbagus hari ini\r",
              "const screenerUrl = 'https://query1.finance.yahoo.com/v1/finance/screener/predefined/saved?scrIds=most_actives&count=5';\r",
              "\r",
              "pm.sendRequest(screenerUrl, function (err, response) {\r",
              "    if (!err) {\r",
              "        let jsonData = response.json();\r",
              "        \r",
              "        // Mengambil kandidat saham terbaik urutan pertama [0] dari hasil screening\r",
              "        let topStock = jsonData.finance.result[0].quotes[0];\r",
              "        \r",
              "        let tickerName = topStock.symbol;        // Mengambil kode saham (misal: NVDA, TSLA)\r",
              "        let currentPrice = topStock.regularMarketPrice; // Mengambil harga live terbaru\r",
              "        let marketVolume = topStock.regularMarketVolume; // Mengambil volume perdagangan\r",
              "        \r",
              "        // Menyimpan hasil screening ke variabel lingkungan Postman\r",
              "        pm.variables.set(\"live_ticker\", tickerName);\r",
              "        pm.variables.set(\"live_price\", currentPrice);\r",
              "        pm.variables.set(\"live_volume\", marketVolume);\r",
              "        pm.variables.set(\"current_time\", Math.floor(Date.now() / 1000));\r",
              "        \r",
              "        console.log(`Berhasil screening! Saham teraktif saat ini: ${tickerName} dengan harga $${currentPrice}`);\r",
              "    } else {\r",
              "        console.log(\"Gagal melakukan screening saham terbaik: \" + err);\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"ticker\": \"{{live_ticker}}\",\r\n    \"price\": {{live_price}},\r\n    \"volume\": {{live_volume}},\r\n    \"timestamp\": {{current_time}}\r\n}",
          "options": {
            "raw": {
              "language": "json"
